# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.py]
indent_size = 4
max_line_length = 100

[*.{tf,tfvars,hcl}]
indent_size = 2

[*.{sh,bash,zsh,ksh}]
indent_size = 2

[*.ps1]
indent_size = 4

[*.{yaml,yml}]
indent_size = 2

[*.json]
indent_size = 2

[*.{toml,ini,cfg}]
indent_size = 2

[*.md]
indent_size = 2
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
